{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m venv:*)",
      "Bash(python -m transcriber:*)",
      "Bash(pip install:*)",
      "Bash(pip show:*)",
      "Bash(pip freeze)",
      "Bash(transcriber:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(ffmpeg -i:*)",
      "Bash(ffmpeg -version)",
      "Bash(ffprobe:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh auth status)"
    ],
    "deny": [
      "Read(./.env)",
      "Bash(git add .env)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_env_writes.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/scrub_hf_token.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/format_python.py\""
          }
        ]
      }
    ]
  }
}
