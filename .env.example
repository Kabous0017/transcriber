# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# Hugging Face read token (https://huggingface.co/settings/tokens).
# Before first use, click "Agree" on all three gated model pages while logged in:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-community-1
# (community-1 is pulled in as a PLDA sub-component by pyannote-audio >= 4.0.)
HF_TOKEN=hf_your_token_here
